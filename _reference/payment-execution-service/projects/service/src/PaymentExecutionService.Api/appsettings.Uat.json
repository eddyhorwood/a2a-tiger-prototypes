{
  "Whitelist": {
    "ClientIds": [
      "xero_invoicing_mybills-bff",
      "xero_data_compliance-dch",
      "xero_collecting-payments-execution_end-to-end-consumer",
      "xero_collecting-payments_collecting-payments-execution-stripe-payments-worker",
      "xero_payments-accounting-treatment_accounting-treatment-context-builder-lambda"
    ]
  },
  "Authorisation": {
    "Environment": "uat"
  },
  "Identity": {
    "Authority": "https://integration-identity.xero-uat.com"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "InternalServices": {
    "PaymentRequestService": {
      "BaseUrl": "https://payment-execution.global.xero-uat.com/requests/"
    },
    "StripeExecutionService": {
      "BaseUrl": "https://payment-execution.global.xero-uat.com/stripe-execution/"
    }
  },
  "ResilienceConfigurations": {
    "EndpointCircuits": {
      "v1.0": {
        "SubmitStripeController": {
          "SubmitPayment": {
            "FailureRatio": 0.1,
            "SamplingDurationSeconds": 5,
            "MinimumThroughput": 2,
            "BreakDurationSeconds": 20
          }
        }
      }
    }
  }
}
