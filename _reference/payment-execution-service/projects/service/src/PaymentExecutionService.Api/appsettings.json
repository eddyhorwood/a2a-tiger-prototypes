{
  "AllowedHosts": "*",
  "SecretHeader": {
    "SecretKeys": "TERCES,DROWSSAP",
    "SecretHeaderName": "X-Secret"
  },
  "Identity": {
    "Client": {
      "ClientId": "xero_collecting-payments-execution_payment-execution-service",
      "ClientSecret": "secret",
      "ClientScopes": [
        "xero_collecting-payments_payment-request-service.submit",
        "xero_collecting-payments_payment-request-service.fail",
        "xero_collecting-payments_collecting-payments-execution-stripe-payments-service.submit",
        "xero_collecting-payments_collecting-payments-execution-stripe-payments-service.readstripepaymentintent",
        "xero_collecting-payments_collecting-payments-execution-stripe-payments-service.cancel"
      ]
    },
    "Authentication": {
      "RequiredScopes": [
        "xero_collecting-payments-execution_payment-execution-service.read",
        "xero_collecting-payments-execution_payment-execution-service.dchdelete",
        "xero_collecting-payments-execution_payment-execution-service.submit",
        "xero_collecting-payments-execution_payment-execution-service.complete",
        "xero_collecting-payments-execution_payment-execution-service.requestcancel",
        "xero_collecting-payments-execution_payment-execution-service.readproviderstate"
      ]
    }
  },
  "Serilog": {
    "Properties": {
      "Application": "PaymentExecutionService.Api"
    },
    "Using": [
      "Serilog.Expressions",
      "PaymentExecutionService"
    ],
    "Enrich": [
      "FromLogContext",
      "WithLogLevel",
      "WithGitHash"
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath = '/ready' and @l in ['Information', 'Debug', 'Trace', 'None']"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath = '/ping' and @l in ['Information', 'Debug', 'Trace', 'None']"
        }
      }
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Polly": "Warning"
      }
    }
  },
  "InternalServices": {
    "PaymentRequestService": {
      "SubmitPaymentRequestEndpoint": "v1/payment-requests/{request-id}/submit",
      "ExecutionSuccessPaymentRequestEndpoint": "v1/payment-requests/{request-id}/execution-succeed",
      "FailurePaymentRequestEndpoint": "v1/payment-requests/{request-id}/fail",
      "GetPaymentRequestByIdEndpoint": "v1/payment-requests/{request-id}"
    },
    "StripeExecutionService": {
      "SubmitEndpoint": "v1/payments/submit",
      "CancelEndpoint": "v1/payments/cancel/{request-id}",
      "GetPaymentIntentEndpoint": "v1/payments/payment-intent?paymentRequestId={payment-request-id}"
    }
  },
  "DataAccess": {
    "PaymentExecutionDB": {
      "ConnectionString": "Server=localhost;Database=payment_execution_db;User Id=payment_execution_user;Password=temp_p@ssw0rd;",
      "MinPoolSize": 3
    }
  },
  "ResilienceConfigurations": {
    "PaymentRequestRetryOptions": {
      "MaxRetryAttempts": 3,
      "DelaySeconds": 5,
      "UseJitter": true
    },
    "StripeExecutionRetryOptions": {
      "MaxRetryAttempts": 3,
      "DelaySeconds": 5,
      "UseJitter": true
    }
  },
  "AWS": {
    "RetryMode": "Standard",
    "MaxErrorRetry": 3
  },
  "LaunchDarkly": {
    "SdkKey": "willBeOverriddenBySecretsManager"
  }
}
