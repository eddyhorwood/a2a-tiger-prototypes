{
  "request": {
    "method": "POST",
    "urlPathPattern": "/v1/payments/submit",
    "headers": {
      "Provider-Account-Id": {
        "matches": "invalid-account-id"
      },
      "Xero-Correlation-Id": {
        "matches": "[0-9A-Fa-f]{8}-([0-9A-Fa-f]{4}-){3}[0-9A-Fa-f]{12}"
      }
    }
  },
  "response": {
    "status": 400,
    "bodyFileName": "stripe-execution-submit-bad-account-id-response.json"
  }
}
