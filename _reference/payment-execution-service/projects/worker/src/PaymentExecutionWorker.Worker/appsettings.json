{
  "Identity": {
    "Client": {
      "ClientId": "xero_collecting-payments-execution_payment-execution-worker",
      "ClientSecret": "secret",
      "ClientScopes": [
        "xero_collecting-payments_payment-request-service.executionsucceed",
        "xero_collecting-payments_payment-request-service.fail",
        "xero_collecting-payments_payment-request-service.read",
        "xero_collecting-payments_payment-request-service.cancelexecutioninprogress"
      ]
    },
    "Authentication": {
      "RequiredScopes": []
    }
  },
  "Serilog": {
    "Properties": {
      "Application": "PaymentExecutionWorker.Worker"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Polly": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ]
  },
  "SqsConfigurations": {
    "ExecutionQueue": {
      "QueueUrl": "http://sqs.ap-southeast-2.localhost.localstack.cloud:4566/000000000000/collectingpayments-execution-payment-execution-queue-test",
      "MaxNumberOfMessages": 10,
      "LogPollingTimeoutSeconds": 20  
    },
    "CancelExecutionQueue": {
      "QueueUrl": "http://sqs.ap-southeast-2.localhost.localstack.cloud:4566/000000000000/collectingpayments-execution-cancel-execution-queue-test"
    }
  },
  "ResilienceConfigurations": {
    "SqsRetryOptions": {
      "MaxRetryAttempts": 3,
      "DelaySeconds": 5,
      "UseJitter": true
    },
    "PaymentRequestRetryOptions": {
      "MaxRetryAttempts": 3,
      "DelaySeconds": 5,
      "UseJitter": true
    }
  },
  "InternalServices": {
    "PaymentRequestService": {
      "SubmitPaymentRequestEndpoint": "v1/payment-requests/{request-id}/submit",
      "ExecutionSuccessPaymentRequestEndpoint": "v1/payment-requests/{request-id}/execution-succeed",
      "FailurePaymentRequestEndpoint": "v1/payment-requests/{request-id}/fail",
      "GetPaymentRequestByIdEndpoint": "v1/payment-requests/{request-id}",
      "CancelExecutionInProgressPaymentRequestEndpoint": "v1/payment-requests/{request-id}/cancel-execution-in-progress"
    }
  },
  "DataAccess": {
    "PaymentExecutionDB": {
      "ConnectionString": "Server=localhost;Database=payment_execution_db;User Id=payment_execution_user;Password=temp_p@ssw0rd;",
      "MinPoolSize": 3
    }
  },
  "LaunchDarkly": {
    "SdkKey": "willBeOverriddenBySecretsManager"
  }
}
