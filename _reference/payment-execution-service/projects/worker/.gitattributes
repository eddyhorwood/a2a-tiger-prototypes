# Use CRLF line endings on Windows, and LF line endings on other platforms.
* text=auto

# Binary file types don't have lines.
*.png binary
*.jpg binary

# Shell scripts require LF line endings.
*.sh text eol=lf
scripts/hooks/* text eol=lf

# Batch scripts and Visual Studio solution files require CRLF line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.sln text eol=crlf

# LF line endings are configured in the .editorconfig file used by dotnet format.
*.cs text eol=lf
*.vb text eol=lf
