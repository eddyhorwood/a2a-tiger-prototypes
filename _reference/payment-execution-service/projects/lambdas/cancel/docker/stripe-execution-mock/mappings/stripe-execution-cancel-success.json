{
  "request": {
    "method": "POST",
    "urlPathPattern": "/v1/payments/cancel/.*",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "Content-Type": {
        "contains": "application/json"
      },
      "Xero-Tenant-Id": {
        "matches": "[0-9A-Fa-f]{8}-([0-9A-Fa-f]{4}-){3}[0-9A-Fa-f]{12}"
      },
      "Xero-Correlation-Id": {
        "matches": "[0-9A-Fa-f]{8}-([0-9A-Fa-f]{4}-){3}[0-9A-Fa-f]{12}"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    }
  }
}