@model A2APaymentsApp.Models.MerchantOnboardingModel

@{
    ViewData["Title"] = "Welcome to Xero Dotnet Sample App";
}

<header class="text-center mb-3">
    <h1 class="mb-1">A2A Bank Transfer Payment Service setup</h1>
    <p class="text-muted">UI for merchants</p>
</header>

<br />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

@if (ViewBag.SubmittedData != null)
{
    <div class="alert alert-info" role="alert">
        <h5>Submitted Data:</h5>
        <p><strong>Bank Account:</strong> @ViewBag.SubmittedData.BankAccountId</p>
        <p><strong>Branding Theme:</strong> @ViewBag.SubmittedData.BrandingThemeId</p>
        <p><strong>Chart of Account Code:</strong> @ViewBag.SubmittedData.ChartOfAccountCode</p>
    </div>
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Organisation Details (compact) -->
            <div class="card mb-3">
                <div class="card-header py-2">
                    <h3 class="card-title h5 mb-0">Organisation Details</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th class="w-25">Name</th>
                                <td>@ViewBag.OrganisationName</td>
                            </tr>
                            <tr>
                                <th>Legal Name</th>
                                <td>@ViewBag.OrganisationLegalName</td>
                            </tr>
                            <tr>
                                <th>Country Code</th>
                                <td>@ViewBag.OrganisationCountryCode</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Payment Services (moved here, compact) -->
            <div class="card mb-4">
                <div class="card-header py-2">
                    <h3 class="card-title h5 mb-0">Available Payment Services</h3>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.PaymentServices != null && ((IEnumerable<SelectListItem>)ViewBag.PaymentServices).Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var ps in (IEnumerable<SelectListItem>)ViewBag.PaymentServices)
                            {
                                <li class="list-group-item py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">@ps.Text</span>
                                    <span class="badge bg-secondary">@ps.Value</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="p-2"><p class="text-muted small mb-0">No payment services available.</p></div>
                    }
                </div>
            </div>
            <!-- Bank and Account information (renamed Merchant Configuration) -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">Bank and Account information</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Index" asp-route-tenantId="@ViewBag.TenantId" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group mb-3">
                            <label asp-for="BankAccountId" class="form-label"></label>
                            <select asp-for="BankAccountId" class="form-select" asp-items="ViewBag.BankAccounts">
                                <option value="">-- Select Bank Account --</option>
                            </select>
                            <span asp-validation-for="BankAccountId" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChartOfAccountCode" class="form-label"></label>
                            <select asp-for="ChartOfAccountCode" class="form-select" asp-items="ViewBag.ChartOfAccountCodes">
                                <option value="">-- Select Chart of Account Code --</option>
                            </select>
                            <span asp-validation-for="ChartOfAccountCode" class="text-danger"></span>
                        </div>
                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-primary btn-lg">Save Configuration</button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Branding Themes info card (updated to include payment services) -->
            <div class="card mb-4">
                <div class="card-header py-2">
                    <h3 class="card-title h5 mb-0">Branding Themes & Payment Services</h3>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.BrandingThemePaymentServices != null && ((IEnumerable<A2APaymentsApp.Models.BrandingThemePaymentServiceInfo>)ViewBag.BrandingThemePaymentServices).Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Theme Name</th>
                                    <th>Theme ID</th>
                                    <th style="width:50%">Payment Services (Name / ID)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bt in (IEnumerable<A2APaymentsApp.Models.BrandingThemePaymentServiceInfo>)ViewBag.BrandingThemePaymentServices)
                                {
                                    <tr>
                                        <td>@bt.BrandingThemeName</td>
                                        <td class="text-muted small">@bt.BrandingThemeId</td>
                                        <td>
                                            @if (bt.PaymentServices != null && bt.PaymentServices.Any())
                                            {
                                                <ul class="list-unstyled mb-0 small">
                                                    @foreach (var ps in bt.PaymentServices)
                                                    {
                                                        <li>@ps.PaymentServiceName <span class="text-muted">(@ps.PaymentServiceId)</span></li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">None</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-2"><p class="text-muted small mb-0">No branding themes available.</p></div>
                    }
                </div>
            </div>
            <!-- Removed original payment services card from bottom -->
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
